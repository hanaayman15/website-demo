# =================================================================
# ENVIRONMENT VARIABLES - COPY TO .env AND FILL IN VALUES
# NEVER commit .env to version control
# =================================================================

# REQUIRED: Secret key for JWT signing (min 32 chars)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-min-32-characters-required

# REQUIRED: Admin credentials
ADMIN_EMAIL=admin@nutrition.com
ADMIN_PASSWORD=your-secure-admin-password-here

# DATABASE
# Development (SQLite) - NOT for production
DATABASE_URL=sqlite:///./nutrition_management.db

# Production (PostgreSQL) - Uncomment and configure:
# DATABASE_URL=postgresql://nutrition_user:STRONG_PASSWORD@localhost:5432/nutrition_db
# Or with explicit driver:
# DATABASE_URL=postgresql+psycopg2://nutrition_user:STRONG_PASSWORD@localhost:5432/nutrition_db

# Remote PostgreSQL (e.g., AWS RDS, Azure, DigitalOcean):
# DATABASE_URL=postgresql://user:pass@your-db-host.region.rds.amazonaws.com:5432/dbname

# PostgreSQL Connection Pool Settings (production only)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# JWT SETTINGS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# APPLICATION
APP_NAME=Client Nutrition Management System
APP_VERSION=1.0.0
DEBUG=False

# SECURITY
RATE_LIMIT_ENABLED=True
LOGIN_RATE_LIMIT=5 per minute

# LOGGING
LOG_LEVEL=INFO
LOG_FORMAT=json

# EMAIL (SMTP) - required for forgot-password verification emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_USE_TLS=True

# CORS
# Production: Your Vercel/Netlify frontend URL
FRONTEND_URL=https://your-app.vercel.app
# Development: Local frontend URLs (optional, for local testing)
CORS_ORIGINS=http://127.0.0.1:5500,http://localhost:5500

# DEPLOYMENT
# Trusted hosts (comma-separated, supports wildcards)
# Use "*" for Render/Railway/Vercel (recommended)
TRUSTED_HOSTS=*
